# DUO DEV FACTORY WEB — variables d'environnement (NOMS UNIQUEMENT, aucune valeur secrète).
# Copier ce fichier en `.env.local` et renseigner les valeurs localement.
# NE JAMAIS committer `.env.local`. NE JAMAIS mettre de secret dans le code.

# --- Application ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Base de données (Turso / libSQL) ---
# En dev : un fichier local libSQL suffit (ex. file:./.data/duo.db).
DATABASE_URL=file:./.data/duo.db
# En prod (Turso) : libsql://<db>-<org>.turso.io  + token
DATABASE_AUTH_TOKEN=

# --- Stockage fichiers ---
# local (dev) | blob (prod Vercel Blob)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.data/storage
BLOB_READ_WRITE_TOKEN=

# --- Authentification (propriétaire) ---
# Secret de signature des sessions (HMAC). OBLIGATOIRE en production. Générer une valeur
# aléatoire longue : openssl rand -hex 32
AUTH_SECRET=
# E-mail du propriétaire (identifiant de connexion).
OWNER_EMAIL=
# Hash scrypt du mot de passe propriétaire. OBLIGATOIRE en production.
# Générer avec : OWNER_PASSWORD='votre-mdp' node scripts/hash-owner-password.mjs
# En développement local, laisser vide active un propriétaire simulé (pas de connexion requise).
OWNER_PASSWORD_HASH=

# --- Worker (connexion sortante complète, protocole V2, plus tard) ---
# Le jeton Worker est stocké HACHÉ côté plateforme. Ne jamais mettre de token en clair ici.
WORKER_REGISTRATION_ENABLED=false

# --- Pont Worker externe (bridge léger V1.5, ex. script bash local orchestrant Claude+Codex) ---
# Active l'endpoint d'ingestion d'événements réels : POST /api/projects/:id/workflow/external-events
WORKER_BRIDGE_ENABLED=false
# Jeton partagé que le script externe doit envoyer via l'en-tête "Authorization: Bearer <token>".
# Générer une valeur aléatoire longue en local (ex. openssl rand -hex 32). Ne jamais committer
# la valeur réelle : elle vit uniquement dans `.env.local`, jamais dans ce fichier ni dans le code.
WORKER_BRIDGE_TOKEN=

# --- Divers ---
RATE_LIMIT_ENABLED=true
